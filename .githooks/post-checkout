#!/usr/bin/env bash
# USMP post-checkout hook — 分支切换后自动验证环境
# 仅在分支切换时触发（非首次 clone，首次需手动 make setup）
set -uo pipefail

# $1 = previous HEAD, $2 = new HEAD, $3 = 1 if branch checkout
CHECKOUT_TYPE="${3:-0}"
if [ "$CHECKOUT_TYPE" != "1" ]; then
  exit 0
fi

# 检查 hooks 是否激活，如果未激活则提示
HOOKS_PATH=$(git config core.hooksPath 2>/dev/null || echo "")
if [ "$HOOKS_PATH" != ".githooks" ]; then
  echo "⚠️  Git Hooks 未激活！运行: make setup"
fi
