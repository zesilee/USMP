#!/usr/bin/env bash
# USMP pre-commit hook вҖ” L3 еҗҲи§„жӢҰжҲӘ
# жӢҰжҲӘ: ж•Ҹж„ҹж–Үд»¶(R16) / generated зӣ®еҪ•(R04) / go vet / go fmt / жөӢиҜ•(R15)
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m'

STAGED_FILES=$(git diff --cached --name-only 2>/dev/null)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

echo -e "${YELLOW}[pre-commit] USMP еҗҲи§„жЈҖжҹҘејҖе§Ӣ...${NC}"
FAILED=0

# в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# 1. ж•Ҹж„ҹж–Үд»¶жү«жҸҸ (R16: зҰҒжӯўжҸҗдәӨ .env / еҜҶй’Ҙ / иҜҒд№Ұ)
# в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
SENSITIVE=$(echo "$STAGED_FILES" | grep -iE '\.(env|pem|key|p12|pfx|jks|keystore)$' || true)
if [ -n "$SENSITIVE" ]; then
  echo -e "${RED}[R16] жӢ’з»қ: жЈҖжөӢеҲ°ж•Ҹж„ҹж–Үд»¶${NC}"
  echo "$SENSITIVE" | sed 's/^/  /'
  FAILED=1
fi

# в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# 2. Generated зӣ®еҪ•дҝқжҠӨ (R04: зҰҒжӯўжүӢеҶҷ YANG з»“жһ„дҪ“)
# в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
GENERATED=$(echo "$STAGED_FILES" | grep -E '^backend/internal/generated/' || true)
if [ -n "$GENERATED" ]; then
  echo -e "${RED}[R04] жӢ’з»қ: жЈҖжөӢеҲ°дҝ®ж”№иҮӘеҠЁз”ҹжҲҗд»Јз Ғ (internal/generated/)${NC}"
  echo "$GENERATED" | sed 's/^/  /'
  echo -e "${YELLOW}  жҸҗзӨә: дҪҝз”Ё yang-ygot-generate жҠҖиғҪйҮҚж–°з”ҹжҲҗпјҢзҰҒжӯўжүӢеҠЁзј–иҫ‘${NC}"
  FAILED=1
fi

# в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# 3. Go vet (йқҷжҖҒеҲҶжһҗ)
# в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
GO_FILES=$(echo "$STAGED_FILES" | grep -E '\.go$' || true)
if [ -n "$GO_FILES" ]; then
  echo -e "${YELLOW}[pre-commit] иҝҗиЎҢ go vet...${NC}"
  if ! (cd backend && go vet ./... 2>&1); then
    echo -e "${RED}[pre-commit] go vet еҸ‘зҺ°й—®йўҳ${NC}"
    FAILED=1
  fi

  # в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  # 4. Go fmt жЈҖжҹҘ
  # в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
  echo -e "${YELLOW}[pre-commit] жЈҖжҹҘ go fmt...${NC}"
  UNFORMATTED=$(cd backend && gofmt -l . 2>/dev/null || true)
  if [ -n "$UNFORMATTED" ]; then
    echo -e "${RED}[pre-commit] д»ҘдёӢж–Үд»¶жңӘж јејҸеҢ–:${NC}"
    echo "$UNFORMATTED" | sed 's/^/  /'
    echo -e "${YELLOW}  дҝ®еӨҚ: cd backend && gofmt -w .${NC}"
    FAILED=1
  fi
fi

# в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# 5. еҸҳжӣҙеҢ…жөӢиҜ• (R15: зҰҒжӯўж— жөӢиҜ•жҸҗдәӨ)
# в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
if [ -n "$GO_FILES" ]; then
  # жҸҗеҸ–еҸҳжӣҙзҡ„ Go package зӣ®еҪ•
  CHANGED_PKGS=$(echo "$GO_FILES" | grep -v '_test\.go$' | xargs -I{} dirname {} | sort -u || true)
  if [ -n "$CHANGED_PKGS" ]; then
    echo -e "${YELLOW}[pre-commit] иҝҗиЎҢеҸҳжӣҙеҢ…жөӢиҜ• (R15)...${NC}"
    for pkg in $CHANGED_PKGS; do
      if ! (cd backend && go test "./${pkg}/..." -count=1 -timeout=30s 2>&1); then
        echo -e "${RED}[R15] жӢ’з»қ: жөӢиҜ•жңӘйҖҡиҝҮ (${pkg})${NC}"
        FAILED=1
      fi
    done
  fi
fi

# в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
# з»“жһң
# в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
if [ "$FAILED" -eq 1 ]; then
  echo -e "${RED}[pre-commit] вқҢ еҗҲи§„жЈҖжҹҘеӨұиҙҘпјҢжҸҗдәӨиў«жӢҰжҲӘ${NC}"
  exit 1
fi

echo -e "${GREEN}[pre-commit] вң… еҗҲи§„жЈҖжҹҘйҖҡиҝҮ${NC}"
exit 0
