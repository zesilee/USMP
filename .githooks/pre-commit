#!/usr/bin/env bash
# USMP pre-commit hook — L3 合规拦截
# 拦截: 敏感文件(R16) / generated 目录(R04) / go vet / go fmt / 测试(R15)
set -euo pipefail

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[0;33m'
NC='\033[0m'

STAGED_FILES=$(git diff --cached --name-only 2>/dev/null)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

echo -e "${YELLOW}[pre-commit] USMP 合规检查开始...${NC}"
FAILED=0

# ──────────────────────────────────────────────
# 1. 敏感文件扫描 (R16: 禁止提交 .env / 密钥 / 证书)
# ──────────────────────────────────────────────
SENSITIVE=$(echo "$STAGED_FILES" | grep -iE '\.(env|pem|key|p12|pfx|jks|keystore)$' || true)
if [ -n "$SENSITIVE" ]; then
  echo -e "${RED}[R16] 拒绝: 检测到敏感文件${NC}"
  echo "$SENSITIVE" | sed 's/^/  /'
  FAILED=1
fi

# ──────────────────────────────────────────────
# 2. Generated 目录保护 (R04: regen-and-diff——生成物改动必须可由管线复现；
#    与 CI compliance 同口径，README/doc.go 等纯文档不触发)
# ──────────────────────────────────────────────
GENERATED=$(echo "$STAGED_FILES" | grep -E '^backend/internal/generated/' | grep -vE '(README\.md|doc\.go)$' || true)
if [ -n "$GENERATED" ]; then
  echo -e "${YELLOW}[pre-commit] 检测到生成物/manifest 变更 → regen-and-diff 验证 (R04)...${NC}"
  if ! make gen-yang >/dev/null 2>&1; then
    echo -e "${RED}[R04] 拒绝: make gen-yang 执行失败（yang-models submodule 已初始化？）${NC}"
    FAILED=1
  elif ! git diff --quiet backend/internal/generated/; then
    echo -e "${RED}[R04] 拒绝: 生成物与 make gen-yang 输出不一致（生成物勿手改，改 YANG/gen.conf 后重跑）${NC}"
    git diff --stat backend/internal/generated/ | sed 's/^/  /'
    FAILED=1
  fi
fi

# ──────────────────────────────────────────────
# 3. Go vet (静态分析)
# ──────────────────────────────────────────────
GO_FILES=$(echo "$STAGED_FILES" | grep -E '\.go$' || true)
if [ -n "$GO_FILES" ]; then
  echo -e "${YELLOW}[pre-commit] 运行 go vet...${NC}"
  if ! (cd backend && go vet ./... 2>&1); then
    echo -e "${RED}[pre-commit] go vet 发现问题${NC}"
    FAILED=1
  fi

  # ──────────────────────────────────────────────
  # 4. Go fmt 检查
  # ──────────────────────────────────────────────
  # 仅检查本次暂存的 Go 文件（与 CI compliance.yml 的 changed-files 口径一致）。
  # 不再全局 `gofmt -l .`：否则本机 gofmt 版本高于仓库目标(go1.21)时，会误报
  # 大量本次未改动的 pre-existing 文件，导致所有 Go 提交被无差别拦截。
  echo -e "${YELLOW}[pre-commit] 检查 go fmt (仅暂存文件)...${NC}"
  UNFORMATTED=$(gofmt -l $GO_FILES 2>/dev/null || true)
  if [ -n "$UNFORMATTED" ]; then
    echo -e "${RED}[pre-commit] 以下暂存文件未格式化:${NC}"
    echo "$UNFORMATTED" | sed 's/^/  /'
    echo -e "${YELLOW}  修复: gofmt -w $UNFORMATTED${NC}"
    FAILED=1
  fi
fi

# ──────────────────────────────────────────────
# 5. 变更包测试 (R15: 禁止无测试提交)
# ──────────────────────────────────────────────
if [ -n "$GO_FILES" ]; then
  # 提取变更的 Go package 目录
  CHANGED_PKGS=$(echo "$GO_FILES" | grep -v '_test\.go$' | xargs -I{} dirname {} | sort -u || true)
  if [ -n "$CHANGED_PKGS" ]; then
    echo -e "${YELLOW}[pre-commit] 运行变更包测试 (R15)...${NC}"
    for pkg in $CHANGED_PKGS; do
      # STAGED_FILES 路径相对仓库根(如 backend/xxx)；测试在 backend 模块内执行，
      # 需剥离 backend/ 前缀，否则会构造出不存在的 ./backend/backend/... 路径。
      case "$pkg" in
        backend/*) rel="${pkg#backend/}" ;;
        backend)   rel="." ;;
        *) continue ;;  # backend 模块外的目录不在此测试
      esac
      # 包目录已删除或不再含 Go 文件（包退役提交）时跳过，避免 no-packages 误判
      if [ "$rel" != "." ] && ! ls backend/"${rel}"/*.go >/dev/null 2>&1; then
        continue
      fi
      if ! (cd backend && go test "./${rel}/..." -count=1 -timeout=30s 2>&1); then
        echo -e "${RED}[R15] 拒绝: 测试未通过 (${pkg})${NC}"
        FAILED=1
      fi
    done
  fi
fi

# ──────────────────────────────────────────────
# 6. 前端变更 → happy-dom 单测 (R15/T09: 前端与后端本地拦截对称)
#    暂存含 frontend/ 源码/测试时跑 npm run test（快，不含 Playwright/浏览器模式）。
#    与后端变更包测试对称，杜绝前端裸提交。USMP_SKIP_FE_TEST=1 显式跳过。
# ──────────────────────────────────────────────
FE_FILES=$(echo "$STAGED_FILES" | grep -E '^frontend/.*\.(ts|tsx|js|vue)$' || true)
if [ -n "$FE_FILES" ] && [ "${USMP_SKIP_FE_TEST:-0}" != 1 ]; then
  echo -e "${YELLOW}[pre-commit] 前端变更 → 运行 happy-dom 单测 (R15/T09)...${NC}"
  if ! (cd frontend && npm run test --silent 2>&1); then
    echo -e "${RED}[pre-commit] 拒绝: 前端单测未通过（修复或 USMP_SKIP_FE_TEST=1 跳过）${NC}"
    FAILED=1
  fi
fi

# ──────────────────────────────────────────────
# 结果
# ──────────────────────────────────────────────
if [ "$FAILED" -eq 1 ]; then
  echo -e "${RED}[pre-commit] ❌ 合规检查失败，提交被拦截${NC}"
  exit 1
fi

echo -e "${GREEN}[pre-commit] ✅ 合规检查通过${NC}"
exit 0
