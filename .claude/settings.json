{
  "plugins": ["superpowers"],
  "superpowers": {
    "autoPlan": true,
    "autoTest": true,
    "autoReview": true
  },
  "permissions": {
    "allow": [
      "Bash(git status *)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(go fmt *)",
      "Bash(go vet *)",
      "Bash(go test *)",
      "Bash(make *)",
      "Bash(chmod +x .githooks/*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/pre-tool-use.sh \"$TOOL_INPUT\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "TaskCreate|TaskUpdate|TaskDelete",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-task-sync.sh"
          }
        ]
      }
    ]
  },
  "attribution": {
    "commit": "Co-Authored-By: Claude Code <noreply@anthropic.com>"
  }
}
