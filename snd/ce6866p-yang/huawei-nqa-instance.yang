  grouping vxlanping-intance-input {
    description
      "Vxlan ping test intance input parameters.";
    leaf vxlan-source-address {
      type inet:ip-address-no-zone;
      description
        "The source address of the NVE interface.";
    }
    leaf vxlan-peer-address {
      type inet:ip-address-no-zone;
      description
        "The address of the remote NVE.";
    }
    leaf vni {
      type uint32 {
        range "1..16777215";
      }
      description
        "The ID of the VNI.";
    }
    leaf dest-udp-port {
      type uint16 {
        range "1..65535";
      }
      description
        "Destination Port Number.";
    }
    leaf source-address {
      type inet:ip-address-no-zone;
      description
        "The source address of the inner packet.";
    }
    leaf reply-mode {
      type vxlan-reply-mode;
      default "udp";
      description
        "Mode for responding to test packets in a test.";
    }
    leaf probe-count {
      type uint32 {
        range "1..15";
      }
      default "3";
      description
        "Number of packets.";
    }
    leaf interval {
      type uint32 {
        range "1..60";
      }
      units "s";
      default "4";
      description
        "Interval for sending packets.";
    }
    leaf timeout {
      type uint32 {
        range "1..60";
      }
      units "s";
      default "3";
      description
        "Time to wait for a response packet after a test packet is sent.";
    }
    leaf tos {
      type uint16 {
        range "0..255";
      }
      default "0";
      description
        "TOS.";
    }
    leaf lb-vxlan-source-port-begin {
      type uint16 {
        range "49152..65535";
      }
      must 'not(../lb-source-address) and not(../lb-destination-address) and not(../lb-protocol) and not(../lb-source-port) and not(../lb-destination-port) and not(../lb-source-mac) and not(../lb-destination-mac)';
      description
        "VXLAN begin source port for load balance.";
    }
    leaf lb-vxlan-source-port-end {
      type uint16 {
        range "49152..65535";
      }
      must 'not(../lb-source-address) and not(../lb-destination-address) and not(../lb-protocol) and not(../lb-source-port) and not(../lb-destination-port) and not(../lb-source-mac) and not(../lb-destination-mac)';
      description
        "VXLAN end source port for load balance.";
    }
    leaf lb-source-address {
      type inet:ipv4-address-no-zone;
      must '../lb-destination-address and ../lb-protocol and ../lb-source-port and ../lb-destination-port and ../lb-source-mac and ../lb-destination-mac and not(../lb-vxlan-source-port-begin) and not(../lb-vxlan-source-port-end)';
      description
        "The source address of the user packet for load balance.";
    }
    leaf lb-destination-address {
      type inet:ipv4-address-no-zone;
      must '../lb-source-address and ../lb-protocol and ../lb-source-port and ../lb-destination-port and ../lb-source-mac and ../lb-destination-mac and not(../lb-vxlan-source-port-begin) and not(../lb-vxlan-source-port-end)';
      description
        "The destination address of the user packet for load balance.";
    }
    leaf lb-protocol {
      type uint8 {
        range "0..255";
      }
      must '../lb-destination-address and ../lb-source-address and ../lb-source-port and ../lb-destination-port and ../lb-source-mac and ../lb-destination-mac and not(../lb-vxlan-source-port-begin) and not(../lb-vxlan-source-port-end)';
      description
        "The protocol of the user packet for load balance.";
    }
    leaf lb-source-port {
      type uint16 {
        range "0..65535";
      }
      must '../lb-destination-address and ../lb-protocol and ../lb-source-address and ../lb-destination-port and ../lb-source-mac and ../lb-destination-mac and not(../lb-vxlan-source-port-begin) and not(../lb-vxlan-source-port-end)';
      description
        "The source port of the user packet for load balance.";
    }
    leaf lb-destination-port {
      type uint16 {
        range "0..65535";
      }
      must '../lb-destination-address and ../lb-protocol and ../lb-source-port and ../lb-source-address and ../lb-source-mac and ../lb-destination-mac and not(../lb-vxlan-source-port-begin) and not(../lb-vxlan-source-port-end)';
      description
        "The destination port of the user packet for load balance.";
    }
    leaf lb-source-mac {
      type pub-type:mac-address;
      must '../lb-destination-address and ../lb-protocol and ../lb-source-port and ../lb-destination-port and ../lb-source-address and ../lb-destination-mac and not(../lb-vxlan-source-port-begin) and not(../lb-vxlan-source-port-end)';
      description
        "The source MAC of the user packet for load balance.";
    }
    leaf lb-destination-mac {
      type pub-type:mac-address;
      must '../lb-destination-address and ../lb-protocol and ../lb-source-port and ../lb-destination-port and ../lb-source-address and ../lb-source-address and not(../lb-vxlan-source-port-begin) and not(../lb-vxlan-source-port-end)';
      description
        "The destination MAC of the user packet for load balance.";
    }
    leaf frequency {
      type uint32 {
        range "1..604800";
      }
      description
        "Result record number of test instance.";
    }
    leaf result-num {
      type uint32 {
        range "1..10";
      }
      default "5";
      description
        "History record number of test instance.";
    }
    leaf history-num {
      type uint32 {
        range "0..1000";
      }
      default "60";
      description
        "Description of test instance.";
    }
    leaf description {
      type string {
        length "1..230";
      }
      description
        "Aging time of test instance.";
    }
    leaf age-time {
      type pub-type:time;
      default "00:00:00";
      description
        "Aging time of test instance.";
    }
  }

  grouping lspping-intance-input {
    description
      "Lsp ping test intance input parameters.";
    choice lsp-protocol {
      description
        "The test-type of LSP.";
      case ip {
        description
          "The test-type of LSP is ldp.";
        container ldp-lsp-ping {
          description
            "Container of ldp lsp ping.";
          leaf dest-address {
            type inet:ipv4-address-no-zone;
            description
              "Destination IP address.";
          }
          leaf mask-len {
            type uint8 {
              range "0..32";
            }
            description
              "LSP IPv4 address prefix mask length.";
          }
          leaf loopback-address {
            type inet:ipv4-address-no-zone;
            description
              "The IP address of the 127.0.0.0/8 network segment in the LSP ping message header.";
          }
          leaf next-hop {
            type inet:ipv4-address-no-zone;
            description
              "Nexthop address.";
          }
          leaf data-fill {
            type string {
              length "1..230";
            }
            description
              "Data padding.";
          }
          leaf reply-mode {
            type ip-lsp-reply-mode-type;
            default "udp";
            description
              "LSP reply mode.";
          }
        }
      }
      case bgp {
        description
          "The test-type of LSP is bgp.";
        container bgp-lsp-ping {
          description
            "Container of bgp lsp ping.";
          leaf dest-address {
            type inet:ipv4-address-no-zone;
            description
              "Destination IP address.";
          }
          leaf mask-len {
            type uint8 {
              range "0..32";
            }
            description
              "LSP IPv4 address prefix mask length.";
          }
          leaf loopback-address {
            type inet:ipv4-address-no-zone;
            description
              "The IP address of the 127.0.0.0/8 network segment in the LSP ping message header.";
          }
          leaf next-hop {
            type inet:ipv4-address-no-zone;
            description
              "Nexthop address.";
          }
          leaf data-fill {
            type string {
              length "1..230";
            }
            description
              "Data padding.";
          }
          leaf reply-mode {
            type ip-lsp-reply-mode-type;
            default "udp";
            description
              "LSP reply mode.";
          }
        }
      }
      case te {
        description
          "The test-type of LSP is te.";
        container te-lsp-ping {
          description
            "Container of te lsp ping.";
          leaf tunnel-name {
            type leafref {
              path "/ifm:ifm/ifm:interfaces/ifm:interface/ifm:name";
            }
            description
              "TE tunnel name.";
          }
          leaf lsp-path {
            type lsp-path;
            description
              "Lsp path.";
          }
          leaf data-fill {
            type string {
              length "1..230";
            }
            description
              "Data padding.";
          }
          leaf reply-mode {
            type lsp-reply-mode-type;
            default "udp";
            description
              "LSP reply mode.";
          }
        }
      }
      case sr-te {
        description
          "The test-type of LSP is sr-te.";
        container sr-te-lsp-ping {
          description
            "Container of sr-te lsp ping.";
          leaf tunnel-name {
            type leafref {
              path "/ifm:ifm/ifm:interfaces/ifm:interface/ifm:name";
            }
            description
              "TE tunnel name.";
          }
          leaf lsp-path {
            type lsp-path;
            description
              "Lsp path.";
          }
          leaf data-fill {
            type string {
              length "1..230";
            }
            description
              "Data padding.";
          }
          leaf reply-mode {
            type srte-lsp-reply-mode-type;
            default "udp";
            description
              "LSP reply mode.";
          }
        }
      }
      case sr-be {
        description
          "The test-type of LSP is sr-be.";
        container sr-be-lsp-ping {
          description
            "Container of sr-be lsp ping.";
          leaf dest-address {
            type inet:ipv4-address-no-zone;
            description
              "Destination IP address.";
          }
          leaf mask-len {
            type uint8 {
              range "0..32";
            }
            description
              "LSP IPv4 address prefix mask length.";
          }
          choice remote-fec {
            description
              "Remote FEC type.";
            case ldp {
              description
                "Remote FEC LDP.";
              container remote-fec-ldp {
                description
                  "Remote FEC LDP.";
                leaf remote-mask-len {
                  type uint8 {
                    range "0..32";
                  }
                  default "0";
                  description
                    "Remote FEC mask length.";
                }
                leaf remote-fec-ip-address {
                  type inet:ipv4-address-no-zone;
                  description
                    "Remote FEC IPv4 address.";
                }
              }
            }
          }
        }
      }
      case srte-policy {
        description
          "The test-type of LSP is srte-policy.";
        container srte-policy-lsp-ping {
          description
            "Container of srte-policy lsp ping.";
          leaf policy-name {
            type string {
              length "1..31";
            }
            must 'not(../color or ../endpoint-ip) and not(../binding-sid)';
            description
              "SRTE policy name.";
          }
          leaf endpoint-ip {
            type inet:ipv4-address-no-zone;
            must 'not(../policy-name) and not(../endpoint-ip) and ../color';
            description
              "Endpoint IP address.";
          }
          leaf color {
            type uint32 {
              range "1..4294967295";
            }
            must 'not(../policy-name) and not(../binding-sid) and ../endpoint-ip';
            description
              "Endpoint color ID.";
          }
          leaf binding-sid {
            type uint32 {
              range "16..1048575";
            }
            must 'not(../policy-name) and not(../color or ../endpoint-ip)';
            description
              "Binding segmentlist ID.";
          }
        }
      }
    }
    leaf timeout {
      type uint32 {
        range "1..60";
      }
      units "s";
      default "3";
      description
        "Time to wait for a response packet after test packets are sent.";
    }
    leaf frag-flag {
      type boolean;
      default "false";
      description
        "Use fragment to send packets.";
    }
    leaf source-address {
      type inet:ipv4-address-no-zone;
      description
        "Source IP address.";
    }
    leaf exp {
      type uint8 {
        range "0..7";
      }
      default "0";
      description
        "Configures the LSP exp value.";
    }
    leaf ttl {
      type uint8 {
        range "1..255";
      }
      default "30";
      description
        "TTL value of NQA test packets.";
    }
    leaf interval {
      type uint32 {
        range "1..60";
      }
      units "s";
      default "4";
      description
        "Interval for sending packets.";
    }
    leaf probe-count {
      type uint32 {
        range "1..15";
      }
      default "3";
      description
        "Number of sent packets.";
    }
    leaf data-size {
      type uint32 {
        range "0..9600";
      }
      default "0";
      description
        "Packet size (byte).";
    }
    leaf fail-percent {
      type uint32 {
        range "1..100";
      }
      default "100";
      description
        "The rate of loss (%) that the test case performed successfully.";
    }
    leaf result-num {
      type uint32 {
        range "1..10";
      }
      default "5";
      description
        "Result record number of test instance.";
    }
    leaf history-num {
      type uint32 {
        range "0..1000";
      }
      default "60";
      description
        "History record number of test instance.";
    }
    leaf description {
      type string {
        length "1..230";
      }
      description
        "Description of test instance.";
    }
    leaf age-time {
      type pub-type:time;
      default "00:00:00";
      description
        "Aging time of test instance.";
    }
    leaf frequency {
      type uint32 {
        range "1..604800";
      }
      description
        "Test instance frequency (s). The frequency must be greater than the value of the following formula; otherwise, the test results may be inaccurate:
         (Number of sent Packets - 1) * (Packet sending interval) + (Timeout period).";
    }
  }

  grouping lsptrace-intance-input {
    description
      "Lsp trace test intance input parameters.";
    choice lsp-protocol {
      description
        "The test-type of LSP.";
      case ipv4 {
        description
          "The test-type of LSP is ldp.";
        container ldp-lsp-trace {
          description
            "Container of ldp lsp trace.";
          leaf dest-address {
            type inet:ipv4-address-no-zone;
            description
              "Destination IP address.";
          }
          leaf mask-len {
            type uint8 {
              range "0..32";
            }
            description
              "LSP IPv4 address prefix mask length.";
          }
          leaf loopback-address {
            type inet:ipv4-address-no-zone;
            description
              "The IP address of the 127.0.0.0/8 network segment in the LSP trace message header.";
          }
          leaf reply-mode {
            type ip-lsp-reply-mode-type;
            default "udp";
            description
              "LSP reply mode.";
          }
        }
      }
      case bgp {
        description
          "The test-type of LSP is bgp.";
        container bgp-lsp-trace {
          description
            "Container of bgp lsp trace.";
          leaf dest-address {
            type inet:ipv4-address-no-zone;
            description
              "Destination IP address.";
          }
          leaf mask-len {
            type uint8 {
              range "0..32";
            }
            description
              "LSP IPv4 address prefix mask length.";
          }
          leaf loopback-address {
            type inet:ipv4-address-no-zone;
            description
              "The IP address of the 127.0.0.0/8 network segment in the LSP trace message header.";
          }
          leaf reply-mode {
            type ip-lsp-reply-mode-type;
            default "udp";
            description
              "LSP reply mode.";
          }
        }
      }
      case te {
        description
          "The test-type of LSP is te.";
        container te-lsp-trace {
          description
            "Container of te lsp trace.";
          leaf tunnel-name {
            type leafref {
              path "/ifm:ifm/ifm:interfaces/ifm:interface/ifm:name";
            }
            description
              "TE tunnel name.";
          }
          leaf lsp-path {
            type lsp-path;
            description
              "Lsp path.";
          }
          leaf reply-mode {
            type lsp-reply-mode-type;
            default "udp";
            description
              "LSP reply mode.";
          }
        }
      }
      case sr-te {
        description
          "The test-type of LSP is sr-te.";
        container sr-te-lsp-trace {
          description
            "Container of sr-te lsp trace.";
          leaf tunnel-name {
            type leafref {
              path "/ifm:ifm/ifm:interfaces/ifm:interface/ifm:name";
            }
            description
              "TE tunnel name.";
          }
          leaf lsp-path {
            type lsp-path;
            description
              "Lsp path.";
          }
          leaf reply-mode {
            type srte-lsp-reply-mode-type;
            default "udp";
            description
              "LSP reply mode.";
          }
        }
      }
      case sr-be {
        description
          "The test-type of LSP is sr-be.";
        container sr-be-lsp-trace {
          description
            "Container of sr-be lsp trace.";
          leaf dest-address {
            type inet:ipv4-address-no-zone;
            description
              "Destination IP address.";
          }
          leaf mask-len {
            type uint8 {
              range "0..32";
            }
            description
              "LSP IPv4 address prefix mask length.";
          }
          choice remote-fec {
            description
              "Remote FEC type.";
            case ldp {
              description
                "Remote FEC LDP.";
              container remote-fec-ldp {
                description
                  "Remote FEC LDP.";
                leaf remote-mask-len {
                  type uint8 {
                    range "0..32";
                  }
                  default "0";
                  description
                    "Remote FEC mask length.";
                }
                leaf remote-fec-ip-address {
                  type inet:ipv4-address-no-zone;
                  description
                    "Remote FEC IPv4 address.";
                }
              }
            }
          }
        }
      }
      case srte-policy {
        description
          "The test-type of LSP is srte-policy.";
        container srte-policy-lsp-trace {
          description
            "Container of srte-policy lsp trace.";
          leaf policy-name {
            type string {
              length "1..31";
            }
            must 'not(../color or ../endpoint-ip) and not(../binding-sid)';
            description
              "SRTE policy name.";
          }
          leaf endpoint-ip {
            type inet:ipv4-address-no-zone;
            must 'not(../policy-name) and not(../endpoint-ip) and ../color';
            description
              "Endpoint IP address.";
          }
          leaf color {
            type uint32 {
              range "1..4294967295";
            }
            must 'not(../policy-name) and not(../binding-sid) and ../endpoint-ip';
            description
              "Endpoint color ID.";
          }
          leaf binding-sid {
            type uint32 {
              range "16..1048575";
            }
            must 'not(../policy-name) and not(../color or ../endpoint-ip)';
            description
              "Binding segmentlist ID.";
          }
        }
      }
    }
    leaf frag-flag {
      type boolean;
      default "false";
      description
        "Use fragment to send packets.";
    }
    leaf exp {
      type uint8 {
        range "0..7";
      }
      default "0";
      description
        "Configures the LSP exp value.";
    }
    leaf probe-count {
      type uint32 {
        range "1..15";
      }
      default "3";
      description
        "Number of sent packets.";
    }
    leaf source-address {
      type inet:ipv4-address-no-zone;
      description
        "Source IP address.";
    }
    leaf first-ttl {
      type uint8 {
        range "1..255";
      }
      must '../first-ttl<=../max-ttl';
      default "1";
      description
        "Packet first TTL.";
    }
    leaf max-ttl {
      type uint8 {
        range "1..255";
      }
      must '../first-ttl<=../max-ttl';
      default "30";
      description
        "Packet maximum TTL.";
    }
    leaf timeout {
      type uint32 {
        range "1..60";
      }
      units "s";
      default "3";
      description
        "Time to wait for a response packet after a test packet is sent.";
    }
    leaf hop-fail-times {
      type uint8 {
        range "1..255";
      }
      default "5";
      description
        "The times of hop failure.";
    }
    leaf result-num {
      type uint32 {
        range "1..10";
      }
      default "5";
      description
        "Result record number of test instance.";
    }
    leaf history-num {
      type uint32 {
        range "0..1000";
      }
      default "60";
      description
        "History record number of test instance.";
    }
    leaf description {
      type string {
        length "1..230";
      }
      description
        "Description of test instance.";
    }
    leaf age-time {
      type pub-type:time;
      default "00:00:00";
      description
        "Aging time of test instance.";
    }
    leaf frequency {
      type uint32 {
        range "1..604800";
      }
      must '(../frequency>=60)';
      description
        "Test instance frequency (s).";
    }
  }

  grouping lsp-jitter-intance-input {
    description
      "Lsp jitter test intance input parameters.";
    choice lsp-protocol {
      description
        "The test-type of LSP.";
      case ipv4 {
        description
          "The test-type of LSP is LDP.";
        container ldp-lsp-jitter {
          description
            "Container of ldp jitter instance.";
          leaf dest-address {
            type inet:ipv4-address-no-zone;
            description
              "Destination IP address. (Must specify the destination address to start the test)";
          }
          leaf mask-len {
            when '../dest-address';
            type uint8 {
              range "0..32";
            }
            must '../dest-address';
            default "0";
            description
              "LSP IPv4 address prefix mask length.";
          }
          leaf loopback-address {
            type inet:ipv4-address-no-zone;
            must '../dest-address';
            description
              "The IP address of the 127.0.0.0/8 network segment in the LSP jitter message header.";
          }
          leaf reply-mode {
            type ip-lsp-reply-mode-type;
            default "udp";
            description
              "LSP reply mode.";
          }
        }
      }
      case te {
        description
          "The test-type of LSP is TE.";
        container te-lsp-jitter {
          presence "Present enable te jitter test intance input.";
          description
            "Container of te jitter instance.";
          leaf tunnel-name {
            type leafref {
              path "/ifm:ifm/ifm:interfaces/ifm:interface/ifm:name";
            }
            description
              "TE tunnel name.";
          }
          leaf lsp-path {
            type lsp-path;
            default "working";
            description
              "Lsp path.";
          }
          leaf reply-mode {
            type lsp-reply-mode-type;
            default "udp";
            description
              "LSP reply mode.";
          }
        }
      }
    }
    leaf timeout {
      type uint32 {
        range "1..60";
      }
      units "s";
      default "3";
      description
        "Time to wait for a response packet after a test packet is sent.";
    }
    leaf frag-flag {
      type boolean;
      default "false";
      description
        "Use fragment to send packets.";
    }
    leaf source-address {
      type inet:ipv4-address-no-zone;
      description
        "Source IP address.";
    }
    leaf exp {
      type uint8 {
        range "0..7";
      }
      default "0";
      description
        "Configures the LSP exp value.";
    }
    leaf ttl {
      type uint8 {
        range "1..255";
      }
      default "30";
      description
        "TTL value of NQA test packets.";
    }
    leaf interval {
      type uint32 {
        range "1..60";
      }
      units "s";
      default "1";
      description
        "Interval for sending packets.";
    }
    leaf probe-count {
      type uint32 {
        range "1..15";
      }
      default "3";
      description
        "Number of probes.";
    }
    leaf jitter-packet-num {
      type uint32 {
        range "1..3000";
      }
      default "20";
      description
        "Number of sent packets.";
    }
    leaf data-size {
      type uint32 {
        range "0..9600";
      }
      units "Byte";
      default "0";
      description
        "Packet size.";
    }
    leaf data-fill {
      type string {
        length "1..230";
      }
      description
        "Data padding.";
    }
    leaf fail-percent {
      type uint32 {
        range "1..100";
      }
      units "%";
      default "100";
      description
        "The rate of loss that the test case performed successfully.";
    }
    leaf result-num {
      type uint32 {
        range "1..10";
      }
      default "5";
      description
        "Result record number of test instance.";
    }
    leaf history-num {
      type uint32 {
        range "0..1000";
      }
      default "60";
      description
        "History record number of test instance.";
    }
    leaf description {
      type string {
        length "1..230";
      }
      description
        "Description of test instance.";
    }
    leaf age-time {
      type pub-type:time;
      default "00:00:00";
      description
        "Aging time of test instance.";
    }
    leaf frequency {
      type uint32 {
        range "1..604800";
      }
      description
        "Test instance frequency (s). The frequency must be greater than the value of the following formula; otherwise, the test results may be inaccurate:
         (Number of sent Packets - 1) * (Packet sending interval) + (Timeout period).";
    }
  }

  grouping pwe3-ping-intance-input {
    description
      "Pwe3 ping test intance input parameters.";
    leaf vc-type {
      type vc-type;
      default "ldp";
      description
        "VC TYPE.";
    }
    leaf local-pw-type {
      type pw-type;
      default "ethernet";
      description
        "Local PW type.";
    }
    leaf local-pw-id {
      type uint32 {
        range "1..4294967295";
      }
      description
        "Local PW ID.";
    }
    leaf label-type {
      type pwe3-label-type;
      default "control-word";
      description
        "Label type.";
    }
    leaf remote-pw-id {
      type uint32 {
        range "1..4294967295";
      }
      description
        "Remote PW ID.";
    }
    leaf dest-address {
      type inet:ipv4-address-no-zone;
      description
        "Destination IP address. (Must specify the destination address to start the test)";
    }
    leaf timeout {
      type uint32 {
        range "1..60";
      }
      units "s";
      default "3";
      description
        "Time to wait for a response packet after a test packet is sent.";
    }
    leaf max-ttl {
      type uint8 {
        range "1..255";
      }
      default "30";
      description
        "Packet maximum TTL.";
    }
    leaf exp {
      type uint8 {
        range "0..7";
      }
      default "0";
      description
        "Configures the Pwe3Ping exp value.";
    }
    leaf reply-mode {
      type lsp-reply-mode-type;
      must "((../reply-mode='no-reply' or ../reply-mode='udp' or ../reply-mode='level-control-channel') )";
      default "udp";
      description
        "Pwe3Ping reply mode.";
    }
    leaf interval {
      type uint32 {
        range "1..60";
      }
      units "s";
      default "4";
      description
        "Set interval time between two packets.";
    }
    leaf probe-count {
      type uint32 {
        range "1..15";
      }
      default "3";
      description
        "Number of sent packets.";
    }
    leaf data-size {
      type uint32 {
        range "0..9600";
      }
      default "0";
      description
        "Specify NQA test packets size.";
    }
    leaf data-fill {
      type string {
        length "1..230";
      }
      description
        "Specify NQA test packets payload string.";
    }
    leaf fail-percent {
      type uint32 {
        range "1..100";
      }
      default "100";
      description
        "Set NQA test fail percent.";
    }
    leaf probe-failtimes {
      type uint32 {
        range "1..15";
      }
      default "1";
      description
        "Packet failed threshold determining whether send traps or events.";
    }
    leaf test-failtimes {
      type uint32 {
        range "1..15";
      }
      default "1";
      description
        "Test failed threshold determining whether send traps or events.";
    }
    leaf threshold-rtd {
      type uint32 {
        range "1..60000";
      }
      description
        "RTD threshold.";
    }
    uses send-trap-enable;
    leaf sender-address {
      type inet:ipv4-address-no-zone;
      description
        "Set the source address of the targeted session.";
    }
    leaf no-cw-flag {
      type boolean;
      must "../label-type and ../label-type!='control-word'";
      default "false";
      description
        "NO control word.";
    }
    leaf ttl-mode {
      type ttl-mode;
      default "uniform";
      description
        "TTL mode.";
    }
    leaf frag-flag {
      type boolean;
      default "false";
      description
        "Use fragment to send packets.";
    }
    leaf peer-address {
      type inet:ipv4-address-no-zone;
      description
        "Peer IP Address.";
    }
    leaf result-num {
      type uint32 {
        range "1..10";
      }
      default "5";
      description
        "Result record number of test instance.";
    }
    leaf history-num {
      type uint32 {
        range "0..1000";
      }
      default "60";
      description
        "History record number of test instance.";
    }
    leaf description {
      type string {
        length "1..230";
      }
      description
        "Description of test instance.";
    }
    leaf age-time {
      type pub-type:time;
      default "00:00:00";
      description
        "Aging time of test instance.";
    }
    leaf frequency {
      type uint32 {
        range "1..604800";
      }
      description
        "Test instance frequency (s). The frequency must be greater than the value of the following formula; otherwise, the test results may be inaccurate:
         (Number of sent Packets - 1) * (Packet sending interval) + (Timeout period).";
    }
  }

  grouping pwe3-trace-intance-input {
    description
      "Pwe3 trace test intance input parameters.";
    leaf vc-type {
      type vc-type;
      default "ldp";
      description
        "VC TYPE.";
    }
    leaf local-pw-type {
      type pw-type;
      default "ethernet";
      description
        "Local PW type.";
    }
    leaf local-pw-id {
      type uint32 {
        range "1..4294967295";
      }
      description
        "Local PW ID.";
    }
    leaf label-type {
      type pwe3-label-type;
      default "control-word";
      description
        "Label type.";
    }
    leaf remote-pw-id {
      type uint32 {
        range "1..4294967295";
      }
      must "../lsp-version!='rfc4379'";
      description
        "Remote PW ID.";
    }
    leaf dest-address {
      type inet:ipv4-address-no-zone;
      description
        "Destination IP address. (Must specify the destination address to start the test)";
    }
    leaf timeout {
      type uint32 {
        range "1..60";
      }
      units "s";
      default "3";
      description
        "Time to wait for a response packet after a test packet is sent.";
    }
    leaf first-ttl {
      type uint8 {
        range "1..255";
      }
      must "(../first-ttl <= ../max-ttl)";
      default "1";
      description
        "Packet first TTL.";
    }
    leaf max-ttl {
      type uint8 {
        range "1..255";
      }
      must "(../max-ttl > ../first-ttl)";
      default "30";
      description
        "Packet maximum TTL.";
    }
    leaf exp {
      type uint8 {
        range "0..7";
      }
      default "0";
      description
        "Configures the Pwe3Trace exp value.";
    }
    leaf reply-mode {
      type lsp-reply-mode-type;
      default "udp";
      description
        "Pwe3Trace reply mode.";
    }
    leaf packet-count {
      type uint32 {
        range "1..15";
      }
      units "packet";
      default "3";
      description
        "Number of sent packets.";
    }
    leaf probe-failtimes {
      type uint32 {
        range "1..15";
      }
      default "1";
      description
        "Packet failed threshold determining whether send traps or events.";
    }
    leaf test-failtimes {
      type uint32 {
        range "1..15";
      }
      default "1";
      description
        "Test failed threshold determining whether send traps or events.";
    }
    leaf lsp-version {
      type lsp-version;
      default "rfc4379";
      description
        "Lsp version.";
    }
    leaf threshold-rtd {
      type uint32 {
        range "1..60000";
      }
      description
        "RTD threshold.";
    }
    leaf send-trap-bits {
      type bits {
        bit rtd {
          position 28;
          description
            "Indicates that a trap is sent when the RTD exceeds the threshold.";
        }
        bit testcomplete {
          position 29;
          description
            "Indicates that a trap is sent when a test succeeds.";
        }
        bit testfailure {
          position 30;
          description
            "Indicates that a trap is sent when the number of test failures reaches the threshold.";
        }
        bit probefailure {
          position 31;
          description
            "Indicates that a trap is sent when the OWD from the source to the
             destination exceeds the threshold.
             This parameter applies only to jitter test instances.";
        }
      }
      description
        "Configures conditions for sending traps.";
    }
    leaf ttl-mode {
      type ttl-mode;
      default "uniform";
      description
        "TTL mode.";
    }
    leaf hop-fail-times {
      type uint8 {
        range "1..255";
      }
      default "5";
      description
        "The times of hop failure.";
    }
    leaf frag-flag {
      type boolean;
      default "false";
      description
        "Use fragment to send packets.";
    }
    leaf peer-address {
      type inet:ipv4-address-no-zone;
      description
        "Peer IP Address.";
    }
    leaf no-cw-flag {
      when "../label-type!='control-word'";
      type boolean;
      default "false";
      description
        "NO control word.";
    }
    leaf result-num {
      type uint32 {
        range "1..10";
      }
      default "5";
      description
        "Result record number of test instance.";
    }
    leaf history-num {
      type uint32 {
        range "0..1000";
      }
      default "60";
      description
        "History record number of test instance.";
    }
    leaf description {
      type string {
        length "1..230";
      }
      description
        "Description of test instance.";
    }
    leaf age-time {
      type pub-type:time;
      default "00:00:00";
      description
        "Aging time of test instance.";
    }
    leaf frequency {
      type uint32 {
        range "1..604800";
      }
      units "s";
      description
        "Test instance frequency. The frequency must be greater than the value of the following formula; otherwise, the test results may be inaccurate:
         (Number of sent Packets - 1) * (Packet sending interval) + (Timeout period).";
    }
  }

  grouping vpls-pw-ping-intance-input {
    description
      "Vpls pw ping test intance input parameters.";
    leaf vsi-name {
