    leaf fail-percent {
      type uint32 {
        range "1..100";
      }
      default "100";
      description
        "Loss ratio (%), determining whether the test is sucessful.";
    }
    leaf interval {
      type uint32 {
        range "1..60";
      }
      units "s";
      default "4";
