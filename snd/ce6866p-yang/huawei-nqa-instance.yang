        range "0..7";
      }
      default "0";
      description
        "Exp value.";
    }
    leaf reply-mode {
      type lsp-reply-mode-type;
      must "((../reply-mode='no-reply' or ../reply-mode='udp' or ../reply-mode='level-control-channel') )";
      default "udp";
      description
        "Mode for responding to test packets in a test.";
    }
    leaf interval {
      type uint32 {
        range "1..60";
      }
      units "s";
      default "4";
      description
        "Interval for sending packets.";
    }
    leaf probe-count {
      type uint32 {
        range "1..15";
      }
      default "3";
      description
        "Number of probes.";
    }
    leaf data-size {
      type uint32 {
        range "0..9600";
      }
      default "0";
      description
        "Packet size (byte).";
    }
    leaf data-fill {
      type string {
        length "1..230";
      }
      description
        "Packing string.";
    }
    leaf fail-percent {
      type uint32 {
        range "1..100";
      }
      default "100";
      description
        "Loss ratio (%), determining whether the test is sucessful.";
    }
    leaf probe-failtimes {
      type uint32 {
        range "1..15";
      }
      default "1";
      description
        "Packet failed threshold determining whether send traps or events.";
    }
    leaf test-failtimes {
      type uint32 {
        range "1..15";
      }
      default "1";
      description
        "Test failed threshold determining whether send traps or events.";
    }
    leaf threshold-rtd {
      type uint32 {
        range "1..60000";
      }
      description
        "Round trip delay time threshold value.";
    }
    uses send-trap-enable;
    leaf sender-address {
      type inet:ipv4-address-no-zone;
      description
        "Sender address.";
    }
    leaf no-cw-flag {
      type boolean;
      default "false";
      description
        "No control-word flag.";
    }
    leaf frag-flag {
      type boolean;
      default "false";
      description
        "Use fragment to send packets.";
    }
    leaf result-num {
      type uint32 {
        range "1..10";
      }
      default "5";
      description
        "Result record number of test instance.";
    }
    leaf history-num {
      type uint32 {
        range "0..1000";
      }
      default "60";
      description
        "History record number of test instance.";
    }
    leaf description {
      type string {
        length "1..230";
      }
      description
        "Description of test instance.";
    }
    leaf age-time {
      type pub-type:time;
      default "00:00:00";
      description
        "Aging time of test instance.";
    }
    leaf frequency {
      type uint32 {
        range "1..604800";
      }
      description
        "Test instance frequency (s). The frequency must be greater than the value of the following formula; otherwise, the test results may be inaccurate:
         (Number of sent Packets - 1) * (Packet sending interval) + (Timeout period).";
    }
  }

  grouping vpls-pw-trace-intance-input {
    description
      "Vpls pw trace test intance input parameters.";
    leaf vsi-name {
      type string {
        length "1..31";
      }
      description
        "Vsi name.";
    }
    leaf peer-address {
      type inet:ipv4-address-no-zone;
      description
        "Peer address.";
    }
    leaf vc-type {
      type vc-type;
      default "ldp";
      description
        "VC type.";
    }
    leaf local-pw-id {
      type uint32 {
        range "1..4294967295";
      }
      description
        "Local PW id.";
    }
    leaf label-type {
      type pwe3-label-type;
      default "label-alert";
      description
        "Label type.";
    }
    leaf timeout {
      type uint32 {
        range "1..60";
      }
      units "s";
      default "3";
      description
        "Time to wait for a response packet after a test packet is sent.";
    }
    leaf first-ttl {
      type uint8 {
        range "1..255";
      }
      default "1";
      description
        "Packet first TTL.";
    }
    leaf max-ttl {
      type uint8 {
        range "1..255";
      }
      default "30";
      description
        "Time to live.";
    }
    leaf exp {
      type uint8 {
        range "0..7";
      }
      default "0";
      description
        "Exp value.";
    }
    leaf reply-mode {
      type lsp-reply-mode-type;
      must "((../reply-mode='no-reply' or ../reply-mode='udp' or ../reply-mode='level-control-channel') )";
      default "udp";
      description
        "Mode for responding to test packets in a test.";
    }
    leaf probe-count {
      type uint32 {
        range "1..15";
      }
      default "3";
      description
        "Number of probes.";
    }
    leaf probe-failtimes {
      type uint32 {
        range "1..15";
      }
      default "1";
      description
        "Packet failed threshold determining whether send traps or events.";
    }
    leaf test-failtimes {
      type uint32 {
        range "1..15";
      }
      default "1";
      description
        "Test failed threshold determining whether send traps or events.";
    }
    leaf threshold-rtd {
      type uint32 {
        range "1..60000";
      }
      description
        "Round trip delay time threshold value.";
    }
    uses send-trap-enable;
    leaf no-cw-flag {
      type boolean;
      default "false";
      description
        "No control-word flag.";
    }
    leaf full-display-flag {
      type boolean;
      default "false";
      description
        "Full path display flag.";
    }
    leaf ttl-mode {
      type ttl-mode;
      default "uniform";
      description
        "TTL mode.";
    }
    leaf hop-fail-times {
      type uint8 {
        range "1..255";
      }
      default "5";
      description
        "The times of hop failure.";
    }
    leaf frag-flag {
      type boolean;
      default "false";
      description
        "Use fragment to send packets.";
    }
    leaf result-num {
      type uint32 {
        range "1..10";
      }
      default "5";
      description
        "Result record number of test instance.";
    }
    leaf history-num {
      type uint32 {
        range "0..1000";
      }
      default "60";
      description
        "History record number of test instance.";
    }
    leaf description {
      type string {
        length "1..230";
      }
      description
        "Description of test instance.";
    }
    leaf age-time {
      type pub-type:time;
      default "00:00:00";
      description
        "Aging time of test instance.";
    }
    leaf frequency {
      type uint32 {
        range "1..604800";
      }
      description
        "Test instance frequency (s). The frequency must be greater than the value of the following formula; otherwise, the test results may be inaccurate:
         (Number of sent Packets - 1) * (Packet sending interval) + (Timeout period).";
    }
  }

  grouping vpls-mac-ping-intance-input {
    description
      "Vpls mac ping test intance input parameters.";
    leaf vsi {
      type string {
        length "1..32";
      }
      description
        "Vsi name.";
    }
    leaf dest-mac-address {
      type pub-type:mac-address;
      description
        "Destination MAC address.";
    }
    leaf vlan {
      type uint16 {
        range "1..4094";
      }
      description
        "VLAN.";
    }
    leaf data-fill {
      type string {
        length "1..231";
      }
      description
        "Message data padding.";
    }
    leaf data-size {
      type uint16 {
        range "100..1442";
      }
      default "100";
      description
        "Packet size (byte).";
    }
    leaf exp {
      type uint8 {
        range "0..7";
      }
      default "0";
      description
        "Exp value.";
    }
    leaf reply-mode {
      type vpls-reply-mode-type;
      default "udp";
      description
        "Mode for responding to test packets in a test.";
    }
    leaf ttl {
      type uint8 {
        range "1..255";
      }
      default "30";
      description
        "Time to live.";
    }
    leaf interval {
      type uint32 {
        range "1..60";
      }
      units "s";
      default "4";
      description
        "Interval for sending packets.";
    }
    leaf fail-percent {
      type uint32 {
        range "1..100";
      }
      default "100";
      description
        "Fail Percent.";
    }
    leaf test-fails {
      type uint32 {
        range "1..15";
      }
      default "1";
      description
        "Test failed threshold determining whether send traps or events.";
    }
    leaf probe-fails {
      type uint32 {
        range "1..15";
      }
      default "1";
      description
        "Packet failed threshold determining whether send traps or events.";
    }
    leaf threshold-rtd {
      type uint32 {
        range "1..60000";
      }
      description
        "Round trip delay time threshold value.";
    }
    uses send-trap-enable;
    leaf probe-count {
      type uint32 {
        range "1..15";
      }
      default "3";
      description
        "Packet Count.";
    }
    leaf timeout {
      type uint32 {
        range "1..60";
      }
      units "s";
      default "3";
      description
        "Time to wait for a response packet after a test packet is sent.";
    }
    leaf result-num {
      type uint32 {
        range "1..10";
      }
      default "5";
      description
        "Result record number of test instance.";
    }
    leaf history-num {
      type uint32 {
        range "0..1000";
      }
      default "60";
      description
        "History record number of test instance.";
    }
    leaf description {
      type string {
        length "1..230";
      }
      description
        "Description of test instance.";
    }
    leaf age-time {
      type pub-type:time;
      default "00:00:00";
      description
        "Aging time of test instance.";
    }
    leaf frequency {
      type uint32 {
        range "1..604800";
      }
      description
        "Test instance frequency (s). The frequency must be greater than the value of the following formula; otherwise, the test results may be inaccurate:
         (Number of sent Packets - 1) * (Packet sending interval) + (Timeout period).";
    }
  }

  grouping mac-ping-intance-input {
    description
      "Mac ping test intance input parameters.";
    leaf dest-mac-address {
      type pub-type:mac-address;
      description
        "Destination MAC address.";
    }
    leaf remote-mep-id {
      type uint16 {
        range "1..8191";
      }
      description
        "Remote MEP ID.";
    }
    leaf mep-id {
      type uint16 {
        range "1..8191";
      }
      description
        "Local MEP ID.";
    }
    leaf md-name {
      type string {
        length "1..44";
      }
      description
        "Name of MD domain.";
    }
    leaf ma-name {
      type string {
        length "1..44";
      }
      description
        "Name of MA domain.";
    }
    leaf probe-count {
      type uint32 {
        range "1..15";
      }
      default "3";
      description
        "Number of probes.";
    }
    leaf jitter-packet-num {
      type uint32 {
        range "1..3000";
      }
      default "1";
      description
        "Number of packets.";
    }
    leaf data-size {
      type uint16 {
        range "64..2000";
      }
      default "95";
      description
        "Packet size (byte).";
    }
    leaf timeout {
      type uint32 {
        range "1..60";
      }
      units "s";
      default "3";
      description
        "Time to wait for a response packet after a test packet is sent.";
    }
    leaf interval {
      type uint32 {
        range "1..60";
      }
      units "s";
      default "4";
      description
        "Interval for sending packets.";
    }
    leaf out-if-name {
      type leafref {
        path "/ifm:ifm/ifm:interfaces/ifm:interface/ifm:name";
      }
      description
        "Out interface name.";
    }
    leaf fail-percent {
      type uint32 {
        range "1..100";
      }
      default "100";
      description
        "Loss ratio (%), determining whether the test is sucessful.";
    }
    leaf test-fails {
      type uint32 {
        range "1..15";
      }
      default "1";
      description
        "Test failed threshold determining whether send traps or events.";
    }
    leaf probe-fails {
      type uint32 {
        range "1..15";
      }
      default "1";
      description
        "Packet failed threshold determining whether send traps or events.";
    }
    leaf threshold-rtd {
      type uint32 {
        range "1..60000";
      }
      description
        "Round trip delay time threshold value.";
    }
    uses send-trap-enable;
    leaf result-num {
      type uint32 {
        range "1..10";
      }
      default "5";
      description
        "Result record number of test instance.";
    }
    leaf history-num {
      type uint32 {
        range "0..1000";
      }
      default "60";
      description
        "History record number of test instance.";
    }
    leaf description {
      type string {
        length "1..230";
      }
      description
        "Description of test instance.";
    }
    leaf age-time {
      type pub-type:time;
      default "00:00:00";
      description
        "Aging time of test instance.";
    }
    leaf frequency {
      type uint32 {
        range "1..604800";
      }
      description
        "Test instance frequency (s).";
    }
  }

  grouping general-flow-intance-input {
    description
      "General flow test intance input parameters.";
    leaf measure {
      type test-measure-type;
      description
        "Test mode.";
    }
    leaf dest-address {
      type inet:ipv4-address-no-zone;
      description
        "Destination IP address.";
    }
    leaf dest-mac-address {
      type pub-type:mac-address;
      description
        "Destination MAC address.";
    }
    leaf source-address {
      type inet:ipv4-address-no-zone;
      must '../dest-address or (not(../dest-address) and not(../source-address))';
      description
        "Source IP address.";
    }
    leaf source-mac-address {
      type pub-type:mac-address;
      description
        "Source MAC address.";
    }
    leaf source-if-name {
      type leafref {
        path "/ifm:ifm/ifm:interfaces/ifm:interface/ifm:name";
      }
      must '../dest-address or (not(../dest-address) and not(../source-if-name))';
      description
        "Source interface name.";
    }
    leaf fwd-simu-if-name {
      type leafref {
        path "/ifm:ifm/ifm:interfaces/ifm:interface/ifm:name";
      }
      description
        "Forwarding-simulation inbound interface.";
    }
    leaf share-mode-enable {
      type boolean;
      must "(../fwd-simu-if-name and ../share-mode-enable='true') or (../share-mode-enable='false')";
      description
        "Enable share mode.";
    }
    leaf duration {
      type uint32 {
        range "10..172800";
      }
      default "60";
      description
        "Test duration time.";
    }
    leaf data-size-list {
      type string {
        length "1..50";
      }
      default "64 128 256 512 1024 1280 1518";
      description
        "Packet size value (byte).";
    }
    leaf tos {
      type uint16 {
        range "0..255";
      }
      must '../dest-address or (not(../dest-address) and ../tos=0)';
      default "0";
      description
        "ToS.";
    }
    leaf rate-low {
      type uint32 {
        range "1..100000000";
      }
      description
        "Lower limit of the rate.";
    }
    leaf rate-high {
      type uint32 {
        range "1..100000000";
      }
      description
        "Upper limit of the rate.";
    }
    leaf ce-vlan {
      type uint16 {
        range "1..4094";
      }
      description
        "PE VLAN ID.";
    }
    leaf pe-vlan {
      type uint16 {
        range "1..4094";
      }
      description
        "CE VLAN ID.";
    }
    leaf interval {
      type uint32 {
        range "1..60";
      }
      units "s";
      default "4";
      description
        "Interval for sending packets.";
    }
    leaf priority {
      type uint8 {
        range "0..7";
      }
      default "0";
      description
        "802.1p priority.";
    }
    leaf precision {
      when "../measure='throughput'";
      type uint32 {
        range "1..10000";
      }
      default "1000";
      description
        "Throughput Test Precision (kbit/s)..";
    }
    leaf fail-ratio {
      type uint32 {
        range "0..10000000";
      }
      default "0";
      description
        "Loss ratio (%), determining whether the test is sucessful.";
    }
    leaf fail-ratio-unit {
      type test-ratio-unit-type;
      must '../fail-ratio or (not(../fail-ratio) and not(../fail-ratio-unit))';
      description
        "Loss ratio unit(10e-4 or 10e-9).";
    }
    leaf exchange-port-enable {
      type boolean;
      default "false";
      description
        "Enable exchange port.";
    }
    leaf rate-class {
      type test-rate-type;
      description
        "Rate class.";
    }
    leaf result-num {
      type uint32 {
        range "1..10";
      }
      default "5";
      description
        "Result record number of test instance.";
    }
    leaf description {
      type string {
        length "1..230";
      }
      description
        "Description of test instance.";
    }
    leaf age-time {
      type pub-type:time;
      default "00:00:00";
      description
        "Aging time of test instance.";
    }
  }

  grouping ethernet-service-intance-input {
    description
      "Ethernet service test intance input parameters.";
    leaf fwd-simu-if-name {
      type leafref {
        path "/ifm:ifm/ifm:interfaces/ifm:interface/ifm:name";
      }
      description
        "Forwarding-simulation inbound interface.";
    }
    leaf config-duration {
      type uint32 {
        range "1..60";
      }
      default "3";
      description
        "Configuration test duration time.";
    }
    leaf perf-duration {
      type uint32 {
        range "1..1440";
      }
      default "15";
      description
        "Performance test duration time.";
    }
    leaf profile {
      type ethsvc-profile;
      default "profile-none";
      description
        "Packet profile.";
    }
    leaf data-size-list {
      type string {
        length "1..50";
      }
      description
        "Packet size value (including the Ethernet packet head).";
    }
    container testflow-ids {
      description
        "Test instance referenced test flow list.";
      uses nqa:testflow-ids-type;
    }
  }

  grouping groups-type {
    description
      "NQA group.";
    list group {
      key "group-name";
      max-elements 16;
      description
        "NQA group.";
      leaf group-name {
        type string {
          length "1..32";
        }
        description
          "NQA group name.";
      }
      container group-members {
        ext:hidden ui;
        description
          "NQA group member.";
        list group-member {
          key "admin-name test-name";
          description
            "NQA group members.";
          leaf admin-name {
            type leafref {
              path "/nqa/instances/instance/admin-name";
            }
            description
              "Admin name.";
          }
          leaf test-name {
            type leafref {
              path "/nqa/instances/instance/test-name";
            }
            description
              "Test name.";
          }
        }
      }
    }
  }
}