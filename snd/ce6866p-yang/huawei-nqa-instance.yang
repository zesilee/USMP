    }
    leaf remote-pw-id {
      type uint32 {
        range "1..4294967295";
      }
      description
        "Remote PW id.";
    }
    leaf remote-address {
      type inet:ipv4-address-no-zone;
      description
        "Remote address.";
    }
    leaf label-type {
