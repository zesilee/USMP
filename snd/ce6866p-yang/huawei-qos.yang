      container interface-configurations {
        ext:hidden ui;
        config false;
        description
          "List of the queryed QoS configuration on interface.";
        list interface-configuration {
          key "interface-name";
          description
            "Operational state of display the QoS configuration on an interface.";
          leaf interface-name {
            type string {
              length "1..127";
            }
            description
              "Interface name.";
          }
          leaf diffserv-domain-name {
            type string {
              length "1..48";
            }
            description
              "Name of a diffserv domain.";
          }
          leaf trust-flag {
            type trust-type;
			description
              "Priority trusting mode on an interface.";
          }
          leaf dei-flag {
            type switch-flag;
			description
              "Whether the DEI field in a VLAN tag is mapped to the drop priority.";
          }
          leaf phbdscp-flag {
            type switch-flag;
		    description
              "Whether the mapping from PHBs to DSCP priorities is enabled for outgoing packets on the interface.";
          }
          leaf phb8021p-flag {
            type switch-flag;
			description
              "Whether the mapping from PHBs to 802.1p priorities is enabled for outgoing packets on the interface.";
          }
          leaf wred-name {
            type string {
              length "1..31";
            }
            description
              "WRED drop profile bound to an interface queue.";
          }
          leaf port-priority {
            type uint8;
          description
              "Default 802.1p priority added to untagged packets by the interface.";
          }
          leaf cir {
            type uint32;
            units "kbit/s";
            description
              "Committed information rate (CIR).";
          }
          leaf cbs {
            type uint32;
            units "Byte";
            description
              "Committed burst size (CBS).";
          }
          leaf port-lr {
            type all-direction-type;
            description
              "Traffic shaping rate on the interface.";
          }
          leaf car-name {
            type string{
              length "1..31";
            }
            description
              "Name of the QoS CAR profile applied to the interface.";
          }
          container queue-configurations {
            description
              "List of the QoS queue configuration on interface.";
            list queue-configuration {
              key "queue-id";
              description
                "Operational state of display the QoS queue configuration on an interface.";
              leaf queue-id {
                type uint8 {
		  range "0..7";
		}
                description
                  "Interface queue index.";
              }
              leaf queue-cir {
                type uint32 {
		   range "1..100000000";
		}
                description
                  "CIR.";
              }
              leaf queue-cbs {
                type uint32 {
		   range "1..268435456";
		}
                description
                  "CBS.";
              }
              leaf queue-pir {
                type uint32 {
		   range "1..100000000";
		}
                description
                  "PIR.";
              }
              leaf queue-pbs {
                type uint32 {
		   range "1..268435456";
		}
                description
                  "PBS.";
              }
              leaf schedule {
                type schedule-type;
                description
                  "Scheduling mode of the interface queue.";
              }
              leaf wred {
                type string {
				length "1..31";
				}
                description
                  "WRED drop profile bound to an interface queue.";
              }
            }
          }
        }
      }
      container interface-monitoring-results {
        config false;
        description
          "List of specify the interfaces to view the congestion monitoring history information of the queue.";
        list interface-monitoring-result {
          key "interface-name queue-id record-number query-type";
          description
            "Operational state of specify the interface to view the congestion monitoring history information of the queue.";
          leaf interface-name {
            type string {
              length "1..127";
            }
            description
              "Monitoring result for interface name.";
          }
          leaf queue-id {
            type uint8 {
              range "0..7";
            }
            description
              "Monitoring result for queue id.";
          }
          leaf record-number {
            type uint8 {
              range "1..64";
            }
            description
              "Monitoring result for record number.";
          }
          leaf query-type {
            type qos-query-type;
            description
              "Monitoring result for Query type.";
          }
          leaf time {
            type yang:date-and-time;
            description
              "Monitoring result for data time.";
          }
          leaf buffer-usage {
            type uint32;
            description
              "Monitoring result for buff usage.";
          }
          leaf percent {
            type uint8;
            units "%";
            description
              "Monitoring result for percent value.";
          }
        }
      }
    }
  }
  rpc reset-interface-traffic-policy-statistics {
    description
      "To clear traffic policy statistics."; 
    ext:node-ref "/qos:qos/qos:global-query/qos:interface-traffic-policy-statisticss";
    input {
      leaf interface-name {
        type leafref {
          path "/ifm:ifm/ifm:interfaces/ifm:interface/ifm:name";
        }
        mandatory true;
        description
          "Interface name.";
      }
      leaf direction {
        type qos-direction-type;
        mandatory true;
        description
