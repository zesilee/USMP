          "label": "access-ports"
        },
        {
          "path": "/business-vlan-service/devices/ip",
          "type": "string",
          "label": "ip",
          "pattern": "([0-9]{1,3}\\.){3}[0-9]{1,3}",
          "isKey": true
        },
        {
          "path": "/business-vlan-service/devices/trunk-ports",
          "type": "leaf-list",
          "label": "trunk-ports"
        }
      ]
    },
    {
      "path": "/business-vlan-service/name",
      "type": "string",
      "label": "name",
      "pattern": "[A-Za-z0-9_-]{1,31}"
    },
    {
      "path": "/business-vlan-service/vlan-id",
      "type": "number",
      "label": "vlan-id",
      "required": true,
      "minimum": 1,
      "maximum": 4094
    }
  ]
}
