          "label": "global",
          "fields": [
            {
              "path": "/mvpn/globals/global/address-family",
              "type": "enum",
              "label": "address-family",
              "options": [
                {
                  "label": "ipv4-unicast",
                  "value": "ipv4-unicast"
                },
                {
                  "label": "ipv6-unicast",
                  "value": "ipv6-unicast"
                }
              ],
              "isKey": true
            },
            {
              "path": "/mvpn/globals/global/apply-explicit-null-label",
              "type": "boolean",
              "label": "apply-explicit-null-label",
              "when": "../address-family='ipv6-unicast'"
            },
            {
              "path": "/mvpn/globals/global/enable-inter-area-segmented",
              "type": "boolean",
              "label": "enable-inter-area-segmented",
              "when": "../address-family='ipv4-unicast'"
            },
            {
              "path": "/mvpn/globals/global/mvpn-id",
              "type": "string",
              "label": "mvpn-id",
              "required": true
            }
          ]
        }
      ]
    },
    {
      "path": "/mvpn/ipv6-underlay-globals",
      "type": "group",
      "label": "ipv6-underlay-globals",
      "fields": [
        {
          "path": "/mvpn/ipv6-underlay-globals/ipv6-underlay-global",
          "type": "list",
          "label": "ipv6-underlay-global",
          "fields": [
            {
              "path": "/mvpn/ipv6-underlay-globals/ipv6-underlay-global/address-family",
              "type": "enum",
              "label": "address-family",
              "options": [
                {
                  "label": "ipv4-unicast",
                  "value": "ipv4-unicast"
                },
                {
                  "label": "ipv6-unicast",
                  "value": "ipv6-unicast"
                }
              ],
              "isKey": true
            },
            {
