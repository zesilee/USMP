              "label": "bit-err-level",
              "fields": [
                {
                  "path": "/mpls/common/bit-err-levels/bit-err-level/level-number",
                  "type": "number",
                  "label": "level-number",
                  "minimum": 1,
                  "maximum": 3,
                  "isKey": true
                },
                {
                  "path": "/mpls/common/bit-err-levels/bit-err-level/resume-coe",
                  "type": "number",
                  "label": "resume-coe",
                  "required": true,
                  "minimum": 1,
                  "maximum": 9
                },
                {
                  "path": "/mpls/common/bit-err-levels/bit-err-level/resume-pow",
                  "type": "number",
                  "label": "resume-pow",
                  "required": true,
                  "minimum": 1,
                  "maximum": 7,
                  "must": [
                    {
                      "expr": "../resume-pow\u003e=../switch-pow"
                    }
                  ]
                },
                {
                  "path": "/mpls/common/bit-err-levels/bit-err-level/switch-coe",
                  "type": "number",
                  "label": "switch-coe",
                  "required": true,
                  "minimum": 1,
                  "maximum": 9,
                  "must": [
                    {
                      "expr": "../switch-pow!=../resume-pow or ../switch-coe\u003e=../resume-coe"
                    }
                  ]
                },
                {
                  "path": "/mpls/common/bit-err-levels/bit-err-level/switch-pow",
                  "type": "number",
                  "label": "switch-pow",
                  "required": true,
                  "minimum": 1,
                  "maximum": 7
                }
              ]
            }
          ]
        },
