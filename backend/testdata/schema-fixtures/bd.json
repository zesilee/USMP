                      "expr": "/evpn:evpn/evpn:instances/evpn:instance[name=current()]/evpn:type='bd-evpn'"
                    }
                  ]
                },
                {
                  "path": "/bd/instances/instance/evpn/tag",
                  "type": "number",
                  "label": "tag",
                  "minimum": 1,
                  "maximum": 4094,
                  "when": "../name",
                  "operationExclude": [
                    "update"
                  ]
                }
              ]
            },
