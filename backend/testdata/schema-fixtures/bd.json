              "label": "evpn",
              "fields": [
                {
                  "path": "/bd/instances/instance/evpn/esi",
                  "type": "string",
                  "label": "esi",
                  "pattern": "( *(00([0-9a-fA-F]){2}\\.(([0-9a-fA-F]){4}\\.){3}(([0-9a-fA-F]){4}))? *)",
                  "when": "../name and ../../nvo3:nvo3/nvo3:vni-list/nvo3:vni[../nvo3:split-horizon='true']"
                },
                {
                  "path": "/bd/instances/instance/evpn/interface-track-peers",
                  "type": "group",
                  "label": "interface-track-peers",
                  "when": "(../name and ../../nvo3:nvo3/nvo3:vni-list/nvo3:vni[../nvo3:split-horizon='true'])",
                  "fields": [
                    {
                      "path": "/bd/instances/instance/evpn/interface-track-peers/interface-track-peer",
                      "type": "list",
                      "label": "interface-track-peer",
                      "fields": [
                        {
                          "path": "/bd/instances/instance/evpn/interface-track-peers/interface-track-peer/es-track-address",
                          "type": "string",
                          "label": "es-track-address",
                          "must": [
                            {
                              "expr": "/ni:network-instance/ni:instances/ni:instance/bgp:bgp/bgp:base-process/bgp:peers/bgp:peer/bgp:afs/bgp:af/bgp-evpn:l2vpn-evpn"
                            }
                          ],
                          "isKey": true
