                  "label": "flag",
                  "readonly": true
                },
                {
                  "path": "/bd/instances/instance/arp-user-entry/ip-addr",
                  "type": "string",
                  "label": "ip-addr",
                  "pattern": "(([0-9]|[1-9][0-9]|1[0-9][0-9]|2[0-4][0-9]|25[0-5])\\.){3}([0-9]|[1-9][0-9]|1[0-9][0-9]|2[0-4][0-9]|25[0-5])(%[\\p{N}\\p{L}]+)?",
                  "readonly": true
                },
                {
                  "path": "/bd/instances/instance/arp-user-entry/mac-addr",
                  "type": "string",
                  "label": "mac-addr",
                  "pattern": "[0-9a-f]{4}(-[0-9a-f]{4}){2}",
                  "readonly": true
                },
                {
                  "path": "/bd/instances/instance/arp-user-entry/vtep",
                  "type": "string",
                  "label": "vtep",
                  "pattern": "(([0-9]|[1-9][0-9]|1[0-9][0-9]|2[0-4][0-9]|25[0-5])\\.){3}([0-9]|[1-9][0-9]|1[0-9][0-9]|2[0-4][0-9]|25[0-5])(%[\\p{N}\\p{L}]+)?",
