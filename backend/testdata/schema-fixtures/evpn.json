{
  "module": "evpn",
  "title": "evpn",
  "vendor": "huawei",
  "fields": [
    {
      "path": "/evpn/base-process",
      "type": "group",
      "label": "base-process",
      "fields": [
        {
          "path": "/evpn/base-process/evpn-overlay",
          "type": "boolean",
          "label": "evpn-overlay",
          "must": [
            {
              "expr": "(../evpn-overlay!='true' and not(../../instances/instance)) or ../evpn-overlay='true'"
            }
          ]
        },
        {
          "path": "/evpn/base-process/redundancy-mode",
          "type": "enum",
          "label": "redundancy-mode",
          "options": [
            {
              "label": "all-active",
              "value": "all-active"
            },
            {
              "label": "single-active",
              "value": "single-active"
            }
          ]
        },
        {
          "path": "/evpn/base-process/source-address",
          "type": "string",
          "label": "source-address",
          "pattern": "(([0-9]|[1-9][0-9]|1[0-9][0-9]|2[0-4][0-9]|25[0-5])\\.){3}([0-9]|[1-9][0-9]|1[0-9][0-9]|2[0-4][0-9]|25[0-5])(%[\\p{N}\\p{L}]+)?",
          "operationExclude": [
            "update"
          ]
        }
      ]
    },
    {
      "path": "/evpn/instances",
      "type": "group",
      "label": "instances",
