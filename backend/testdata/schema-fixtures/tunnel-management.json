          "type": "list",
          "label": "tunnel-policy",
          "fields": [
            {
              "path": "/tunnel-management/tunnel-policys/tunnel-policy/description",
              "type": "string",
              "label": "description"
            },
            {
              "path": "/tunnel-management/tunnel-policys/tunnel-policy/ipv4-set",
              "type": "group",
              "label": "ipv4-set",
              "fields": [
                {
                  "path": "/tunnel-management/tunnel-policys/tunnel-policy/ipv4-set/policy-type",
                  "type": "choice",
                  "label": "policy-type",
                  "cases": [
                    {
                      "name": "binding",
                      "label": "binding",
                      "fields": [
                        {
                          "path": "/tunnel-management/tunnel-policys/tunnel-policy/ipv4-set/nexthops",
                          "type": "group",
                          "label": "nexthops",
                          "fields": [
                            {
                              "path": "/tunnel-management/tunnel-policys/tunnel-policy/ipv4-set/nexthops/nexthop",
                              "type": "list",
                              "label": "nexthop",
                              "fields": [
                                {
                                  "path": "/tunnel-management/tunnel-policys/tunnel-policy/ipv4-set/nexthops/nexthop/address",
                                  "type": "string",
                                  "label": "address",
                                  "pattern": "(([0-9]|[1-9][0-9]|1[0-9][0-9]|2[0-4][0-9]|25[0-5])\\.){3}([0-9]|[1-9][0-9]|1[0-9][0-9]|2[0-4][0-9]|25[0-5])(%[\\p{N}\\p{L}]+)?",
                                  "isKey": true
                                },
                                {
                                  "path": "/tunnel-management/tunnel-policys/tunnel-policy/ipv4-set/nexthops/nexthop/auto-names",
                                  "type": "group",
                                  "label": "auto-names",
                                  "when": "../bind-type='auto'",
                                  "fields": [
                                    {
                                      "path": "/tunnel-management/tunnel-policys/tunnel-policy/ipv4-set/nexthops/nexthop/auto-names/auto-name",
                                      "type": "list",
                                      "label": "auto-name",
                                      "fields": [
                                        {
                                          "path": "/tunnel-management/tunnel-policys/tunnel-policy/ipv4-set/nexthops/nexthop/auto-names/auto-name/name",
                                          "type": "string",
                                          "label": "name",
                                          "isKey": true
                                        }
                                      ]
                                    }
                                  ]
                                },
                                {
                                  "path": "/tunnel-management/tunnel-policys/tunnel-policy/ipv4-set/nexthops/nexthop/bind-type",
                                  "type": "enum",
                                  "label": "bind-type",
                                  "required": true,
                                  "options": [
                                    {
                                      "label": "auto",
                                      "value": "auto"
                                    },
                                    {
                                      "label": "sr-te-policy-group",
                                      "value": "sr-te-policy-group"
                                    },
                                    {
                                      "label": "te",
                                      "value": "te"
                                    }
                                  ]
                                },
                                {
                                  "path": "/tunnel-management/tunnel-policys/tunnel-policy/ipv4-set/nexthops/nexthop/down-switch",
                                  "type": "boolean",
                                  "label": "down-switch",
                                  "must": [
                                    {
                                      "expr": "(../down-switch='true' and ../include-ldp='false') or ../down-switch='false'"
                                    }
                                  ]
                                },
                                {
                                  "path": "/tunnel-management/tunnel-policys/tunnel-policy/ipv4-set/nexthops/nexthop/ignore-destination-check",
                                  "type": "boolean",
                                  "label": "ignore-destination-check"
                                },
                                {
                                  "path": "/tunnel-management/tunnel-policys/tunnel-policy/ipv4-set/nexthops/nexthop/include-ldp",
                                  "type": "boolean",
                                  "label": "include-ldp",
                                  "must": [
                                    {
                                      "expr": "../include-ldp='false' or (../bind-type='te' and ../down-switch='false')"
                                    }
                                  ]
                                },
                                {
                                  "path": "/tunnel-management/tunnel-policys/tunnel-policy/ipv4-set/nexthops/nexthop/tunnel-names",
                                  "type": "group",
                                  "label": "tunnel-names",
                                  "when": "../bind-type='te'",
                                  "fields": [
                                    {
                                      "path": "/tunnel-management/tunnel-policys/tunnel-policy/ipv4-set/nexthops/nexthop/tunnel-names/tunnel-name",
                                      "type": "list",
                                      "label": "tunnel-name",
                                      "fields": [
                                        {
                                          "path": "/tunnel-management/tunnel-policys/tunnel-policy/ipv4-set/nexthops/nexthop/tunnel-names/tunnel-name/name",
                                          "type": "string",
                                          "label": "name",
                                          "must": [
                                            {
                                              "expr": "/ifm:ifm/ifm:interfaces/ifm:interface[ifm:name=current()]/ifm:type='Tunnel'"
                                            }
                                          ],
                                          "isKey": true
                                        }
                                      ]
                                    }
                                  ]
                                }
                              ]
                            }
                          ]
                        }
                      ]
                    },
