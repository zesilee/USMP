                                        {
                                          "label": "sr-te-policy",
                                          "value": "sr-te-policy"
                                        },
                                        {
                                          "label": "srbe-lsp",
                                          "value": "srbe-lsp"
                                        },
                                        {
                                          "label": "te",
                                          "value": "te"
                                        }
                                      ],
                                      "must": [
                                        {
                                          "expr": "(../type='sr-te-policy' and ../../../unmix = 'true') or (../type != 'sr-te-policy')"
                                        }
                                      ],
                                      "isKey": true
                                    }
                                  ]
                                }
                              ]
                            },
                            {
                              "path": "/tunnel-management/tunnel-policys/tunnel-policy/ipv4-set/select-sequence/unmix",
                              "type": "boolean",
                              "label": "unmix"
                            }
                          ],
                          "presence": true
                        }
