                              "type": "boolean",
                              "label": "unmix",
                              "must": [
                                {
                                  "expr": "(../select-tunnel-types/select-tunnel-type[type = 'srv6-te-policy'] and ../select-tunnel-types/select-tunnel-type[type = 'srv6-te-policy-group'] and ../unmix = 'true') or (../unmix = 'false')"
                                }
