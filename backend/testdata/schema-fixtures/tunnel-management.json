                                      "label": "type",
                                      "options": [
                                        {
                                          "label": "bgp",
                                          "value": "bgp"
                                        },
                                        {
                                          "label": "cr-lsp",
                                          "value": "cr-lsp"
                                        },
                                        {
                                          "label": "gre",
                                          "value": "gre"
                                        },
                                        {
                                          "label": "ldp",
                                          "value": "ldp"
                                        },
                                        {
                                          "label": "lsp",
                                          "value": "lsp"
                                        },
                                        {
                                          "label": "sr-te",
                                          "value": "sr-te"
