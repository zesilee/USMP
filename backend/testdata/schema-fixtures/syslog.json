              "type": "string",
              "label": "ssl-policy-name",
              "must": [
                {
                  "expr": "../transport-mode='tcp'"
                }
              ]
            },
            {
              "path": "/syslog/domain-servers/domain-server/timestamp",
              "type": "enum",
              "label": "timestamp",
              "options": [
                {
                  "label": "UTC",
                  "value": "UTC"
                },
                {
                  "label": "localtime",
                  "value": "localtime"
                }
              ]
            },
            {
              "path": "/syslog/domain-servers/domain-server/transport-mode",
              "type": "enum",
              "label": "transport-mode",
              "options": [
                {
                  "label": "tcp",
                  "value": "tcp"
                },
                {
                  "label": "udp",
                  "value": "udp"
                }
              ]
            },
            {
              "path": "/syslog/domain-servers/domain-server/vrf-name",
              "type": "string",
              "label": "vrf-name",
              "must": [
                {
                  "expr": "not(../is-default-vpn='true') or (../is-default-vpn='true' and ../vrf-name='_public_')"
                }
              ],
              "isKey": true
            }
          ]
        }
      ]
    },
