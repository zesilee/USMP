                {
                  "label": "debugging",
                  "value": "debugging"
                },
                {
                  "label": "emergencies",
                  "value": "emergencies"
                },
                {
                  "label": "error",
                  "value": "error"
                },
                {
                  "label": "informational",
                  "value": "informational"
                },
                {
                  "label": "notification",
                  "value": "notification"
                },
                {
                  "label": "warning",
                  "value": "warning"
                }
