{
  "module": "m-lag",
  "title": "m-lag",
  "vendor": "huawei",
  "fields": [
    {
      "path": "/m-lag/dfs-groups",
      "type": "group",
      "label": "dfs-groups",
      "fields": [
        {
          "path": "/m-lag/dfs-groups/dfs-group",
          "type": "list",
          "label": "dfs-group",
          "fields": [
            {
              "path": "/m-lag/dfs-groups/dfs-group/authentication",
              "type": "group",
              "label": "authentication",
              "fields": [
                {
                  "path": "/m-lag/dfs-groups/dfs-group/authentication/mode",
                  "type": "enum",
                  "label": "mode",
                  "required": true,
                  "options": [
                    {
                      "label": "hmac-sha256",
                      "value": "hmac-sha256"
                    }
                  ]
                },
                {
                  "path": "/m-lag/dfs-groups/dfs-group/authentication/password",
                  "type": "string",
                  "label": "password",
                  "required": true
                }
              ],
              "presence": true
            },
            {
              "path": "/m-lag/dfs-groups/dfs-group/consistency-check",
              "type": "group",
              "label": "consistency-check",
              "fields": [
                {
                  "path": "/m-lag/dfs-groups/dfs-group/consistency-check/mode",
                  "type": "enum",
                  "label": "mode",
                  "options": [
                    {
                      "label": "disable",
                      "value": "disable"
                    },
                    {
                      "label": "loose",
                      "value": "loose"
                    },
                    {
                      "label": "strict",
                      "value": "strict"
                    }
                  ]
                }
              ]
            },
            {
              "path": "/m-lag/dfs-groups/dfs-group/dad-error-down",
              "type": "group",
              "label": "dad-error-down",
              "fields": [
                {
                  "path": "/m-lag/dfs-groups/dfs-group/dad-error-down/delay",
                  "type": "number",
                  "label": "delay",
                  "maximum": 7200,
                  "when": "../enable ='true'"
                },
                {
                  "path": "/m-lag/dfs-groups/dfs-group/dad-error-down/enable",
                  "type": "boolean",
                  "label": "enable"
                },
                {
                  "path": "/m-lag/dfs-groups/dfs-group/dad-error-down/error-down-mode",
                  "type": "enum",
                  "label": "error-down-mode",
                  "options": [
                    {
                      "label": "routing-switch",
                      "value": "routing-switch"
                    }
                  ]
                }
              ]
            },
            {
              "path": "/m-lag/dfs-groups/dfs-group/group-id",
              "type": "number",
              "label": "group-id",
              "minimum": 1,
              "maximum": 1,
              "isKey": true
            },
            {
              "path": "/m-lag/dfs-groups/dfs-group/lacp-switch-delay",
