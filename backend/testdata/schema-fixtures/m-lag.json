                {
                  "path": "/m-lag/dfs-groups/dfs-group/lacp-switch-delay/system-id-switch-mode",
                  "type": "choice",
                  "label": "system-id-switch-mode",
                  "cases": [
                    {
                      "name": "immediately",
                      "label": "immediately",
                      "fields": [
                        {
                          "path": "/m-lag/dfs-groups/dfs-group/lacp-switch-delay/immediately",
                          "type": "string",
                          "label": "immediately"
                        }
                      ]
                    },
                    {
                      "name": "no-switch",
                      "label": "no-switch",
                      "fields": [
                        {
                          "path": "/m-lag/dfs-groups/dfs-group/lacp-switch-delay/no-switch",
                          "type": "string",
                          "label": "no-switch"
                        }
                      ]
                    },
                    {
                      "name": "switch-delay",
                      "label": "switch-delay",
                      "fields": [
                        {
                          "path": "/m-lag/dfs-groups/dfs-group/lacp-switch-delay/delay-timer",
                          "type": "number",
                          "label": "delay-timer",
                          "minimum": 1,
                          "maximum": 3600
                        }
                      ]
                    }
                  ]
                }
              ]
            },
            {
              "path": "/m-lag/dfs-groups/dfs-group/mac-address-remain",
