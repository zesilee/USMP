                  "label": "unpaired-port"
                }
              ]
            },
            {
              "path": "/m-lag/dfs-groups/dfs-group/priority",
              "type": "number",
              "label": "priority",
              "minimum": 1,
              "maximum": 254
            },
            {
              "path": "/m-lag/dfs-groups/dfs-group/sessions",
              "type": "group",
              "label": "sessions",
              "fields": [
                {
                  "path": "/m-lag/dfs-groups/dfs-group/sessions/session",
                  "type": "list",
                  "label": "session",
                  "fields": [
                    {
                      "path": "/m-lag/dfs-groups/dfs-group/sessions/session/dfs-proto-type",
                      "type": "enum",
                      "label": "dfs-proto-type",
                      "options": [
                        {
                          "label": "keepalive",
                          "value": "keepalive"
                        }
                      ],
                      "isKey": true
                    },
                    {
                      "path": "/m-lag/dfs-groups/dfs-group/sessions/session/peer-ip",
                      "type": "string",
                      "label": "peer-ip",
                      "must": [
                        {
                          "expr": "(../peer-ip != ../source-ip)"
                        }
                      ]
                    },
                    {
                      "path": "/m-lag/dfs-groups/dfs-group/sessions/session/peer-port",
                      "type": "number",
                      "label": "peer-port",
                      "minimum": 1025,
                      "maximum": 2048,
                      "must": [
                        {
                          "expr": "(../peer-ip and ../peer-port) or (not (../peer-ip) and not (../peer-port))"
                        }
                      ]
                    },
                    {
                      "path": "/m-lag/dfs-groups/dfs-group/sessions/session/socket-type",
                      "type": "enum",
                      "label": "socket-type",
                      "options": [
                        {
                          "label": "UDP",
                          "value": "UDP"
                        }
                      ],
                      "must": [
                        {
                          "expr": "(../peer-ip and ../socket-type) or (not (../peer-ip) and not (../socket-type))"
                        }
                      ]
                    },
                    {
                      "path": "/m-lag/dfs-groups/dfs-group/sessions/session/source-ip",
                      "type": "string",
                      "label": "source-ip",
                      "required": true
                    },
                    {
                      "path": "/m-lag/dfs-groups/dfs-group/sessions/session/timeout",
                      "type": "number",
                      "label": "timeout",
                      "minimum": 3,
                      "maximum": 60,
                      "when": "../dfs-proto-type ='keepalive'"
                    },
                    {
                      "path": "/m-lag/dfs-groups/dfs-group/sessions/session/vpn-name",
                      "type": "string",
                      "label": "vpn-name"
                    }
                  ]
                }
              ]
            },
            {
              "path": "/m-lag/dfs-groups/dfs-group/up-delay",
