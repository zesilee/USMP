            {
              "path": "/unicast-forward/ipv6-ttl-expired-forwards/ipv6-ttl-expired-forward/ipv6-nexthop-addrs",
              "type": "group",
              "label": "ipv6-nexthop-addrs",
              "fields": [
                {
                  "path": "/unicast-forward/ipv6-ttl-expired-forwards/ipv6-ttl-expired-forward/ipv6-nexthop-addrs/ipv6-nexthop-addr",
                  "type": "list",
                  "label": "ipv6-nexthop-addr",
