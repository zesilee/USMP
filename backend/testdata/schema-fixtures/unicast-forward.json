          "fields": [
            {
              "path": "/unicast-forward/ipv4-ttl-expired-forwards/ipv4-ttl-expired-forward/ipv4-nexthop-addrs",
              "type": "group",
              "label": "ipv4-nexthop-addrs",
              "fields": [
                {
                  "path": "/unicast-forward/ipv4-ttl-expired-forwards/ipv4-ttl-expired-forward/ipv4-nexthop-addrs/ipv4-nexthop-addr",
                  "type": "list",
                  "label": "ipv4-nexthop-addr",
                  "fields": [
                    {
                      "path": "/unicast-forward/ipv4-ttl-expired-forwards/ipv4-ttl-expired-forward/ipv4-nexthop-addrs/ipv4-nexthop-addr/ipv4-address",
                      "type": "string",
                      "label": "ipv4-address",
                      "pattern": "(([0-9]|[1-9][0-9]|1[0-9][0-9]|2[0-4][0-9]|25[0-5])\\.){3}([0-9]|[1-9][0-9]|1[0-9][0-9]|2[0-4][0-9]|25[0-5])(%[\\p{N}\\p{L}]+)?",
                      "isKey": true
                    },
                    {
                      "path": "/unicast-forward/ipv4-ttl-expired-forwards/ipv4-ttl-expired-forward/ipv4-nexthop-addrs/ipv4-nexthop-addr/vpn-instance-name",
                      "type": "string",
                      "label": "vpn-instance-name",
                      "isKey": true
                    }
                  ]
                }
              ]
            },
            {
              "path": "/unicast-forward/ipv4-ttl-expired-forwards/ipv4-ttl-expired-forward/nexthop-group-id",
              "type": "number",
              "label": "nexthop-group-id",
              "minimum": 1,
              "maximum": 4,
              "isKey": true
            }
          ]
        }
