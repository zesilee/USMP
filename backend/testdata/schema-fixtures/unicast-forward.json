    {
      "path": "/unicast-forward/backup-groups",
      "type": "group",
      "label": "backup-groups",
      "fields": [
        {
          "path": "/unicast-forward/backup-groups/backup-group",
          "type": "list",
          "label": "backup-group",
          "fields": [
            {
              "path": "/unicast-forward/backup-groups/backup-group/backup-group-name",
              "type": "string",
              "label": "backup-group-name",
              "isKey": true
            },
            {
              "path": "/unicast-forward/backup-groups/backup-group/if-name1",
              "type": "string",
              "label": "if-name1",
              "required": true,
              "must": [
                {
                  "expr": "/ifm:ifm/ifm:interfaces/ifm:interface[ifm:name = current()]/ifm:type='Eth-Trunk'"
                },
                {
                  "expr": "/ifm:ifm/ifm:interfaces/ifm:interface[ifm:name = current()]/ethernet:ethernet/ethernet:main-interface/ethernet:l2-attribute"
                }
              ]
            },
            {
              "path": "/unicast-forward/backup-groups/backup-group/if-name2",
              "type": "string",
              "label": "if-name2",
              "required": true,
              "must": [
                {
                  "expr": "/ifm:ifm/ifm:interfaces/ifm:interface[ifm:name = current()]/ifm:type='Eth-Trunk'"
                },
                {
                  "expr": "/ifm:ifm/ifm:interfaces/ifm:interface[ifm:name = current()]/ethernet:ethernet/ethernet:main-interface/ethernet:l2-attribute"
                },
                {
                  "expr": "count(../../backup-group[if-name1=current()])=0"
                }
              ]
            }
          ]
        }
      ]
    },
