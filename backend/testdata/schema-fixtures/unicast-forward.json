                      "path": "/unicast-forward/ipv6-ttl-expired-forwards/ipv6-ttl-expired-forward/ipv6-nexthop-addrs/ipv6-nexthop-addr/ipv6-address",
                      "type": "string",
                      "label": "ipv6-address",
                      "pattern": "((:|[0-9a-fA-F]{0,4}):)([0-9a-fA-F]{0,4}:){0,5}((([0-9a-fA-F]{0,4}:)?(:|[0-9a-fA-F]{0,4}))|(((25[0-5]|2[0-4][0-9]|[01]?[0-9]?[0-9])\\.){3}(25[0-5]|2[0-4][0-9]|[01]?[0-9]?[0-9])))(%[\\p{N}\\p{L}]+)?",
                      "isKey": true
                    },
                    {
                      "path": "/unicast-forward/ipv6-ttl-expired-forwards/ipv6-ttl-expired-forward/ipv6-nexthop-addrs/ipv6-nexthop-addr/vpn-instance-name",
                      "type": "string",
