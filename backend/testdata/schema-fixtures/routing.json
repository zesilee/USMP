              "type": "string",
              "label": "ipv4-prefix-ref",
              "when": "../enable='true'",
              "must": [
                {
                  "expr": "../enable='true' or not(../ipv4-prefix-ref)"
                }
              ]
            },
            {
              "path": "/routing/routing-manage/relay-tunnel/tunnel-policy-ref",
              "type": "string",
              "label": "tunnel-policy-ref",
              "when": "../enable='true'",
              "must": [
                {
                  "expr": "../enable='true' or not(../tunnel-policy-ref)"
                }
