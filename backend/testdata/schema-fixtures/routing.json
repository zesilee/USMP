          "label": "relay-default-routes",
          "fields": [
            {
              "path": "/routing/routing-manage/relay-default-routes/relay-default-route",
              "type": "list",
              "label": "relay-default-route",
              "fields": [
                {
                  "path": "/routing/routing-manage/relay-default-routes/relay-default-route/address-family",
                  "type": "enum",
                  "label": "address-family",
                  "options": [
                    {
                      "label": "ipv4-unicast",
                      "value": "ipv4-unicast"
                    },
                    {
                      "label": "ipv6-unicast",
                      "value": "ipv6-unicast"
                    }
                  ],
                  "must": [
                    {
                      "expr": "../address-family='ipv4-unicast' or (not(../protocol-type='msr') and ../address-family='ipv6-unicast')"
                    }
                  ],
                  "isKey": true
                },
                {
                  "path": "/routing/routing-manage/relay-default-routes/relay-default-route/protocol-type",
                  "type": "enum",
                  "label": "protocol-type",
                  "options": [
                    {
                      "label": "msr",
                      "value": "msr"
                    },
                    {
                      "label": "static",
                      "value": "static"
                    }
                  ],
                  "must": [
                    {
                      "expr": "../protocol-type='static' or (../protocol-type='msr' and ../address-family='ipv4-unicast')"
                    }
                  ],
                  "isKey": true
                }
              ]
            }
          ]
        },
        {
          "path": "/routing/routing-manage/relay-label",
